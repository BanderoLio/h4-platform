# Production environment for the Next.js frontend.
# The browser calls the same-origin BFF proxy (/api); the proxy forwards
# to the backend below with the API key injected server-side.

# Internal backend URL reachable from the frontend container.
BACKEND_INTERNAL_URL=http://web:8000

# Backend API key (must match API_KEY in the backend .env).
API_KEY=changeme

# Next.js output mode (standalone is required for the Docker image).
NEXT_OUTPUT=standalone
