# --- Server-side only (never shipped to the browser) ---------------------

# Internal backend URL the Next.js BFF proxy forwards to.
# Local dev: http://localhost:8000. In Docker Compose: http://web:8000.
BACKEND_INTERNAL_URL=http://localhost:8000

# Backend API key. The BFF proxy injects it as a Bearer token server-side.
# Must match API_KEY in the backend .env.
API_KEY=changeme

# --- Build-time -----------------------------------------------------------

# Next.js output mode (standalone is required for the Docker image).
NEXT_OUTPUT=standalone

# --- Optional -------------------------------------------------------------

# Escape hatch: call a backend origin directly from the browser instead of
# the BFF proxy. Only for a public, unauthenticated backend. Leave unset
# normally — the proxy keeps the API key off the client.
# NEXT_PUBLIC_API_BASE_URL=
