# =============================================================================
# agentsec (LLM) — used when running the REAL agentsec orchestrator locally.
# The bundled Docker stack ships the agentsec stub and does not need these.
# =============================================================================

# OpenAI-совместимый эндпоинт. Подходит OpenAI, OpenRouter, Ollama, vLLM, LM Studio и пр.
#   OpenAI:     OPENAI_BASE_URL оставь пустым (берётся дефолт)
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1
#   vLLM:       http://localhost:8000/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=your-key-here
MODEL=gpt-4o-mini

# =============================================================================
# Docker Compose full stack (docker-compose.yml at the repo root).
# =============================================================================

# Shared API key. The backend requires it on every /scan request; the
# frontend BFF proxy injects it server-side. Both services read the same value.
API_KEY=changeme

# Backend webhook bearer secret (required by the backend settings).
WEBHOOK_TOKEN=changeme-webhook

# Host port the nginx entrypoint is published on -> http://localhost:<HTTP_PORT>
HTTP_PORT=8080

# Host port the backend is published on, for the agent-scan CLI.
# CLI usage: SCAN_API_URL=http://localhost:<BACKEND_PORT> SCAN_API_KEY=<API_KEY>
BACKEND_PORT=8000

# agentsec stub outcome for simulated scans:
#   instant_completed | instant_failed | awaiting_clarify | awaiting_gate | running
AGENTSEC_STUB_BEHAVIOR=instant_completed
