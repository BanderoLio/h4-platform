API_KEY=changeme

API_PORT_INTERNAL=8000
API_PORT_EXTERNAL=8000

REDIS_PASSWORD=changeme_redis_strong_secret
REDIS_URL=redis://:changeme_redis_strong_secret@redis:6379
REDIS_PORT_EXTERNAL=6380

DATABASE_URL=sqlite+aiosqlite:////data/db/scans.db
