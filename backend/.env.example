# Optional: enable scanning local/internal code without git-clone.
# Absolute directories, os.pathsep-separated (':' Unix, ';' Windows).
# A /scan/start request may pass repo_path only if it resolves inside one
# of these roots. Leave empty to disable local-path scanning entirely.
ALLOWED_LOCAL_ROOTS=
